# Environment Variables for Production Deployment

# Server Configuration
PORT=5000
NODE_ENV=production
FRONTEND_URL=https://yourdomain.com

# Database Configuration (choose one or both)
# MySQL Database
MYSQL_HOST=your-mysql-host
MYSQL_USER=your-mysql-user
MYSQL_PASSWORD=your-mysql-password
MYSQL_DATABASE=your-database-name

# MongoDB Database
MONGO_URI=mongodb://username:password@host:port/database

# Alternative: Use MongoDB only (set to 'true' to skip MySQL)
USE_MONGO=false

# Authentication
JWT_SECRET=your-super-secure-jwt-secret-here
JWT_EXPIRY=7d

# Payment Processing
# PayPal (Sandbox for testing, change to live for production)
PAYPAL_CLIENT_ID=your-paypal-client-id
PAYPAL_SECRET=your-paypal-secret

# Stripe
STRIPE_SECRET=sk_test_your-stripe-secret-key

# Email Configuration (optional, for notifications)
EMAIL_FROM=noreply@yourdomain.com

# Database Connection Pool (optional optimizations)
DB_CONNECTION_LIMIT=10
DB_ACQUIRE_TIMEOUT=10000