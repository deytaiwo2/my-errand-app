# Environment Variables for Render + MongoDB Deployment

# Server Configuration
PORT=10000
NODE_ENV=production
FRONTEND_URL=https://yourdomain.com

# Database Configuration (MongoDB only)
USE_MONGO=true
MONGO_URI=mongodb+srv://username:password@cluster.mongodb.net/database

# Authentication
JWT_SECRET=your-super-secure-jwt-secret-here-make-it-long-and-random
JWT_EXPIRY=7d

# Payment Processing
# PayPal (Sandbox for testing, change to live for production)
PAYPAL_CLIENT_ID=your-paypal-client-id
PAYPAL_SECRET=your-paypal-secret

# Stripe
STRIPE_SECRET=sk_test_your-stripe-secret-key

# Email Configuration (optional, for notifications)
EMAIL_FROM=noreply@yourdomain.com