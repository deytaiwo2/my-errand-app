# Backend Environment Variables for Cloudflare Workers
# Copy this to .env.production and fill in your actual values
# Then add these to Cloudflare Dashboard under Workers settings

# API Configuration
ENVIRONMENT=production
API_PORT=3000

# Database Configuration
# MySQL: mysql2://username:password@host:port/database
# MongoDB: mongodb+srv://username:password@cluster.mongodb.net/database
DATABASE_URL=your_database_connection_string_here

# JWT & Security
JWT_SECRET=your_jwt_secret_key_here
JWT_EXPIRY=7d
BCRYPT_ROUNDS=10

# Payment Providers
STRIPE_SECRET_KEY=sk_test_your_stripe_key_here
PAYPAL_SECRET=your_paypal_secret_here

# Email Configuration
EMAIL_SERVICE=gmail
EMAIL_USER=your_gmail@gmail.com
EMAIL_PASSWORD=your_app_password

# Socket.IO Configuration
SOCKET_IO_CORS_ORIGIN=https://your-domain.com

# CORS Configuration
CORS_ORIGIN=https://your-domain.com

# Node Environment
NODE_ENV=production
